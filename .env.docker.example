# Docker environment example (MongoDB Atlas)

NODE_ENV=production
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/subscriptionManagementDB

# JWT
JWT_SECRET=change_this_to_a_secure_random_key_min_32_chars
JWT_EXPIRE=7d

# Webhook
WEBHOOK_SECRET=change_this_to_a_secure_webhook_secret

# Swagger production base URL (local when running Docker)
PRODUCTION_BASE_URL=http://localhost:5000
